# Root Docker build context ignore rules

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Version control
.git
.gitignore

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.env
*.env.*
*.db
*.sqlite
*.sqlite3
*.log
venv/
ENV/
env/
.build/

# Build artifacts and temporary files
build/
dist/
*.egg-info/
.pytest_cache/

# Docker build and runtime
Dockerfile
.dockerignore

# Large dataset and generated folders
Gold Dataset/
Silver Dataset/
data/
models/
reports/
logs/
instance/

# Node and frontend artifacts
**/node_modules/
**/.next/
**/out/
**/dist/
**/npm-debug.log
**/yarn-error.log
**/pnpm-debug.log
