{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${CLAUDE_PROJECT_DIR}/frontend-next\" && npx eslint --fix --quiet \"${CLAUDE_TOOL_INPUT_FILE_PATH}\" 2>/dev/null || true"
          }
        ],
        "condition": "file_extension_matches",
        "pattern": "\\.(ts|tsx)$"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'BLOCKED: .env files must not be edited by Claude. Use the actual env management workflow instead.' && exit 1"
          }
        ],
        "condition": "file_matches",
        "pattern": "\\.env"
      }
    ]
  }
}
