VITE_STORAGE_KEY=dev-storage-key-not-for-production

VITE_SESSION_TIMEOUT=900000
VITE_SESSION_WARNING_TIME=60000

VITE_DEFAULT_ASSET=XAUUSD
VITE_REFRESH_INTERVAL=30000
